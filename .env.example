# ── Database (Neon PostgreSQL) ──────────────────────────────
# Format: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=

# ── Auth.js (Google login) ──────────────────────────────────
# Generate a secret with:  npx auth secret
AUTH_SECRET=

# Google OAuth credentials from https://console.cloud.google.com/apis/credentials
# Authorized redirect URI must be:
#   http://localhost:3000/api/auth/callback/google   (local dev)
#   https://your-domain.com/api/auth/callback/google  (production)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ── Notes ───────────────────────────────────────────────────
# API keys for AI providers (OpenAI, Groq, etc.) are NOT set here.
# Users enter them manually in the app; keys live in the browser only.
